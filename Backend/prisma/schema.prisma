// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Team {
  id          String   @id @default(cuid())
  teamName    String
  teamCode    String   @unique
  password    String
  rawPassword String?
  score       Int      @default(0)
  round1Score Float    @default(0)
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  buzzes       BuzzHistory[]
  quizAttempts QuizAttempt[]
  quizSession  QuizSession?
  scoreLogs    ScoreLog[]
}

model Question {
  id               String   @id @default(cuid())
  questionText     String
  optionA          String?
  optionB          String?
  optionC          String?
  optionD          String?
  correctAnswer    String
  roundNumber      Int      @default(1)
  orderIndex       Int
  points           Int      @default(10)
  timeLimitSeconds Int      @default(30)
  createdAt        DateTime @default(now())

  attempts QuizAttempt[]
}

model BuzzHistory {
  id            String   @id @default(cuid())
  teamId        String
  questionId    String
  buzzTimeMs    BigInt
  wasFirst      Boolean  @default(false)
  wasCorrect    Boolean?
  pointsAwarded Int      @default(0)
  createdAt     DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([questionId, buzzTimeMs])
}

model RoundControl {
  id          String   @id @default(cuid())
  roundNumber Int      @unique
  isLive      Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

model QuizAttempt {
  id             String   @id @default(cuid())
  teamId         String
  questionId     String
  selectedAnswer String
  isCorrect      Boolean
  timeTakenMs    Int
  score          Float
  submittedAt    DateTime @default(now())

  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@unique([teamId, questionId])
}

model QuizSession {
  id                   String    @id @default(cuid())
  teamId               String    @unique
  currentQuestionIndex Int       @default(0)
  startedAt            DateTime  @default(now())
  completedAt          DateTime?
  totalScore           Float     @default(0)
  isDisqualified       Boolean   @default(false)
  disqualifyReason     String?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model ScoreLog {
  id             String   @id @default(cuid())
  teamId         String
  roundNumber    Int      @default(2)
  questionNumber Int?
  points         Int
  createdAt      DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([roundNumber, questionNumber])
}
