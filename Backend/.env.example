# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis connection string (Upstash or Railway)
REDIS_URL=redis://default:password@host:port

# JWT Secrets (use long random strings)
JWT_SECRET=your_team_jwt_secret_here_min_32_chars
ADMIN_JWT_SECRET=your_admin_jwt_secret_here_min_32_chars

# Server port
PORT=5000
