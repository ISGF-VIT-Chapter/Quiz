{
    "name": "quizmaster-backend",
    "version": "1.0.0",
    "description": "QuizMaster Pro Backend — Express + Socket.IO + PostgreSQL + Redis",
    "main": "server.js",
    "type": "commonjs",
    "scripts": {
        "build": "npx prisma generate",
        "start": "node server.js",
        "dev": "nodemon server.js",
        "db:generate": "npx prisma generate",
        "db:push": "npx prisma db push",
        "db:migrate": "npx prisma migrate dev",
        "db:studio": "npx prisma studio",
        "seed": "node seed/seedAdmin.js",
        "seed:rounds": "node seed/seedRounds.js",
        "seed:questions": "node seedQuestions.js"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.6.1",
        "express": "^4.19.2",
        "ioredis": "^5.4.1",
        "jsonwebtoken": "^9.0.2",
        "@prisma/client": "^6.5.0",
        "socket.io": "^4.7.5"
    },
    "devDependencies": {
        "nodemon": "^3.1.2",
        "prisma": "^6.5.0"
    }
}
